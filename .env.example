# --- Required ---
# Neon gives you a URL like:
#   postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# Change the scheme to postgresql+asyncpg:// and drop the ?sslmode=require part
# (TLS is handled in code). Example:
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.region.aws.neon.tech/dbname

# --- Auth (required) ---
# Generate one with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-string

# --- Google Books API (optional — avoids rate limits on book search) ---
# Enable at: https://console.cloud.google.com/ → APIs & Services → Google Books API
# GOOGLE_BOOKS_API_KEY=your-key-here

# --- Optional: turns on embeddings, image search, and the clerk agent ---
# Free key, no credit card: https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# --- Production: lock CORS to your frontend ---
# CORS_ORIGINS=["https://your-app.vercel.app"]
